# Optional: public CSV export URL from your Google Sheet (see public/events/README.md).
# If unset, `npm run build` keeps the existing src/content/events.json.
# EVENTS_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv&gid=0

# Optional: override media base for self-hosted images (see src/data/constants.ts).
# VITE_MEDIA_BASE=https://your-cdn.example.com/wp-content/uploads
