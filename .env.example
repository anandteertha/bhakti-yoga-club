# Optional: simulate GitHub Pages project-site URL locally (repo at /your-repo-name/).
# VITE_BASE_PATH=your-repo-name

# Live events: paste either the Google Sheet tab URL (with gid), a “Publish to web” link, or CSV export URL.
# Examples:
# https://docs.google.com/spreadsheets/d/SHEET_ID/edit#gid=0
# https://docs.google.com/spreadsheets/d/SHEET_ID/export?format=csv&gid=0
# Published sheet (pub / pubhtml, or output=xlsx — the app normalizes to CSV text):
# https://docs.google.com/spreadsheets/d/e/2PACX-.../pub?output=csv
# Share the sheet: Anyone with the link -> Viewer.
# The site fetches this on every page load / refresh (no rebuild needed).
VITE_EVENTS_SHEET_CSV_URL=

# Build-time sync: writes src/content/events.json (optional; for CI or offline bundles).
# Can be the same URL as above.
EVENTS_SHEET_CSV_URL=

# Optional: override media base for self-hosted images (see src/data/constants.ts).
# VITE_MEDIA_BASE=https://your-cdn.example.com/wp-content/uploads
